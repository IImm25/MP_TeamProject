# Description: Complex headcount check (attempt 2).
# Scenario: A1 requires 2 mechanics. P1 is the only mechanic available.
# Reasoning: Since personOnBoat[p,b] is binary, P1 can contribute at most 1 to the mechanic count.
# Therefore the maximum achievable sum for Mech is 1, which is below the required 2.
# The QualiCheck constraint makes A1 infeasible. Combined with AtLeastOneTaskGlobal (which forces
# at least one task), the problem has no valid solution.
# Expected result: INFEASIBLE – the solver finds no valid solution.
# Maximize WorkHours: INFEASIBLE.
data;
set TASKS := A1;
set QUALIS := Mech;
set PEOPLE := P1;
set TOOLS := W1;

param amountBoats := 1;
param maxWorkingHours := 8;

param duration := A1 5;

param hasQuali :=
P1 Mech 1;

param requiredQualis :=
A1 Mech 2;

param requiredTools :=
A1 W1 0;

param stockTools := W1 0;
end;
