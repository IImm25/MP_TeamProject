# TC-12: Two tasks fixed to boat 1, ta_1 at position 1, ta_2 at position 2
# ta_3 is a new emergency task to be inserted
# Expect: after[1,ta_1,ta_2] = 1 must hold (order preserved)
# UC-05 invariant: FIXED task sequence is never altered
data;

set TASKS  := ta_1 ta_2 ta_3;
set PEOPLE := p_1 p_2;
set QUALIS := q_1;
set TOOLS  := to_1;
set PLACES := w_1 w_2 w_3 w_4;

param amountBoats    := 2;
param maxWorkingHours := 8;
param drivingSpeed   := 36;
param harbor         := 'w_1';

param duration :=
      ta_1 1.0
      ta_2 1.0
      ta_3 1.0;

param taskPrio :=
      ta_1 5
      ta_2 5
      ta_3 9;

param taskLocation :=
      ta_1 w_2
      ta_2 w_3
      ta_3 w_4;

param distance : w_1 w_2 w_3 w_4 :=
                 w_1  0  36  36  36
                 w_2 36   0  36  36
                 w_3 36  36   0  36
                 w_4 36  36  36   0;

param hasQuali : q_1 :=
      p_1        1
      p_2        1;

param requiredQualis : q_1 :=
      ta_1        1
      ta_2        1
      ta_3        1;

param requiredTools : to_1 :=
      ta_1         1
      ta_2         1
      ta_3         1;

param stockTools := to_1 10;

param fixedBoat :=
      ta_1 1
      ta_2 1
      ta_3 -1;

param fixedPerson := p_1 1 p_2 -1;

param fixedToolAmount : to_1 :=
      1            1
      2            0;

end;
