# TC-02: Two tasks, two boats - verify symmetry breaking
# Expect: OPTIMAL, boat 1 gets at least one task before boat 2 is used
# UC-04: System must fill boats in ascending order
data;

set TASKS  := ta_1 ta_2;
set PEOPLE := p_1 p_2;
set QUALIS := q_1;
set TOOLS  := to_1;
set PLACES := w_1 w_2 w_3;

param amountBoats    := 2;
param maxWorkingHours := 8;
param drivingSpeed   := 36;
param harbor         := 'w_1';

param duration :=
      ta_1 1.0
      ta_2 1.0;

param taskPrio :=
      ta_1 5
      ta_2 5;

param taskLocation :=
      ta_1 w_2
      ta_2 w_3;

param distance : w_1 w_2 w_3 :=
                 w_1  0  36  36
                 w_2 36   0  36
                 w_3 36  36   0;

param hasQuali : q_1 :=
      p_1        1
      p_2        1;

param requiredQualis : q_1 :=
      ta_1        1
      ta_2        1;

param requiredTools : to_1 :=
      ta_1         1
      ta_2         1;

param stockTools := to_1 10;

end;
