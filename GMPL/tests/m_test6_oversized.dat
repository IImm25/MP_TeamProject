# Description: Task too large – A1 has a duration of 10h with a limit of 8h.
# Expected result: WorkHours = 0.
# Reasoning: As in m_test5, A1 cannot be scheduled because it exceeds the per-boat time limit.
# Since the model is a maximization and DoneAtMostOnce (≤ 1) applies, the optimal solution is to not execute A1.
# Maximize WorkHours: 0.
data;
set TASKS := A1;
set QUALIS := Tech;
set PEOPLE := P1;
set TOOLS := W1;

param amountBoats := 1;

param duration := A1 10;
param maxWorkingHours := 8;

param hasQuali :=
P1 Tech 1;

param requiredQualis :=
A1 Tech 1;

param requiredTools :=
A1 W1 1;

param stockTools := W1 1;
end;
