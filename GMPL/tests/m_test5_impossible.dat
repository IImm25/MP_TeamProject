# Description: Infeasible case – task A1 (10h) exceeds maxWorkingHours (8h).
# Expected result: INFEASIBLE. No tasks are completed.
# Reasoning: A1 cannot be scheduled because it exceeds the per-boat time limit.
# The AtLeastOneTaskGlobal constraint forces at least one task to be planned,
# but A1 is the only task and it violates the TimeLimit constraint.
# This makes the problem infeasible – the solver finds no valid solution.
# Maximize WorkHours: INFEASIBLE.
data;
set TASKS := A1;
set QUALIS := Techniker;
set PEOPLE := P1;
set TOOLS := W1;

param amountBoats := 1;

param duration := A1 10;
param maxWorkingHours := 8;

param hasQuali :=
P1 Techniker 1;

param requiredQualis :=
A1 Techniker 1;

param requiredTools :=
A1 W1 1;

param stockTools := W1 1;
end;
