# Beschreibung: Headcount vs Multi-Quali Extremfall
# Szenario:
# - Aufgabe A1 benötigt 2x Q1 (z.B. zwei Mechaniker).
# - P1 hat Q1 UND Q2 UND Q3.
# - P1 ist alleine auf dem Boot.
# - Erwartung: A1 kann NICHT ausgeführt werden (da Headcount=2 erforderlich).
# - Aufgabe A2 benötigt 1x Q1, 1x Q2, 1x Q3.
# - Erwartung: A2 KANN von P1 alleine ausgeführt werden (da kollektive Qualis auf Boot).
# Maximize WorkHours: 4.
data;
set TASKS := A1 A2;
set QUALIS := Q1 Q2 Q3;
set PEOPLE := P1;
set TOOLS := W1;

param amountBoats := 1;
param maxWorkingHours := 10;

param duration := A1 10 A2 4;

param hasQuali := 
P1 Q1 1
P1 Q2 1
P1 Q3 1;

param requiredQualis := 
A1 Q1 2 A1 Q2 0 A1 Q3 0
A2 Q1 1 A2 Q2 1 A2 Q3 1;

param requiredTools := A1 W1 0 A2 W1 0;
param stockTools := W1 0;
end;
