# TC-09: Weather speed reduction - same scenario as TC-01 but speed halved
# At 36 km/h: travel=1h each way, task=2h -> total=4h -> fits in 8h
# At 18 km/h: travel=2h each way, task=2h -> total=6h -> still fits
# At 9  km/h: travel=4h each way, task=2h -> total=10h -> INFEASIBLE
# UC-06: reduced speed forces tasks to be dropped from schedule
data;

set TASKS  := ta_1;
set PEOPLE := p_1;
set QUALIS := q_1;
set TOOLS  := to_1;
set PLACES := w_1 w_2;

param amountBoats    := 1;
param maxWorkingHours := 8;
param drivingSpeed   := 9;
param harbor         := 'w_1';

param duration := ta_1 2.0;

param taskPrio := ta_1 5;

param taskLocation := ta_1 w_2;

param distance : w_1 w_2 :=
                 w_1  0  36
                 w_2 36   0;

param hasQuali : q_1 :=
      p_1        1;

param requiredQualis : q_1 :=
      ta_1        1;

param requiredTools : to_1 :=
      ta_1         1;

param stockTools := to_1 5;

end;
