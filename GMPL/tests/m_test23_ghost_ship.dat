# Description: Ghost ship scenario.
# Scenario: Task A1 requires no qualifications (requiredQualis = 0). No people are assigned to the boat.
# Reasoning: The current model does not enforce a constraint requiring at least one person when a task is assigned.
# Therefore, tasks without qualification requirements can be executed on a "crewless" boat.
# Expected result: WorkHours = 5 (task is executed without personnel).
# Note: If a crew requirement constraint existed (taskOnBoat > 0 ⇒ at least one person), this case would fail.
# Maximize WorkHours: 5.
data;
set TASKS := A1;
set QUALIS := Tech;
set PEOPLE := P1;
set TOOLS := W1;

param amountBoats := 1;
param maxWorkingHours := 10;

param duration := A1 5;

param hasQuali := P1 Tech 1;
param requiredQualis := A1 Tech 0;
param requiredTools := A1 W1 0;
param stockTools := W1 10;
end;
