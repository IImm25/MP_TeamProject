# TC-20: MINIMAL isolation of the TC-19 finding, with only ONE task and ONE boat, to prove
# unambiguously that the bug is in TimeLimit's interaction with FIXED tasks (not a side effect
# of multi-boat/multi-task interactions).
# ta_1 is FIXED (already running) on the only boat. A weather event drops drivingSpeed so low
# that the return-to-harbor leg alone exceeds maxWorkingHours.
# Per UC-06 ("Running tasks are atomic and are always finished even if the reduced speed
# causes delayed returns to the harbor") and UC-05's invariant ("Tasks with status FIXED...
# cannot be altered, moved, or removed by the system"), the system must NOT report this as
# infeasible - ta_1 must remain scheduled regardless of how long the return trip now takes.
# Expect (per the use cases): OPTIMAL, ta_1 still scheduled on boat 1, even though
# lastTaskStart[1] + duration + travelTime-to-harbor mathematically exceeds maxWorkingHours.
# ACTUAL (current model): infeasible, because TimeLimit has no carve-out for fixedBoat[ta]>0.
# This test is EXPECTED TO FAIL against the current model.mod - it documents a genuine gap
# between UC-06's stated invariant and the TimeLimit constraint's implementation.
data;

set TASKS  := ta_1;
set PEOPLE := p_1;
set QUALIS := q_1;
set TOOLS  := to_1;
set PLACES := w_1 w_2;

param amountBoats    := 1;
param maxWorkingHours := 4;
param drivingSpeed   := 4;
param harbor         := 'w_1';

# distance 18km @ 4km/h = 4.5h one-way travel ALONE already exceeds the 4h budget;
# plus the 1h task duration, total far exceeds maxWorkingHours.
param duration := ta_1 1.0;

param taskPrio := ta_1 9;

param taskLocation := ta_1 w_2;

param distance : w_1 w_2 :=
                 w_1   0  18
                 w_2  18   0;

param hasQuali : q_1 :=
      p_1        1;

param requiredQualis : q_1 :=
      ta_1        1;

param requiredTools : to_1 :=
      ta_1         1;

param stockTools := to_1 5;

# ta_1 is already running (FIXED) when the weather change hits - must finish regardless
param fixedBoat  := ta_1 1;
param fixedPerson := p_1 1;
param fixedToolAmount : to_1 :=
      1            1;

end;
