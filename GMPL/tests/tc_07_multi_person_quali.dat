# TC-07: ta_1 needs 3x q_1 AND 2x q_2 - impossible for a single boat (only 2 people total)
# UC-03: tasks can require multiple persons with the same qualification
# This is based on the comment in planned_dat_file.txt: "schafft kein Boot allein!"
# Expect: INFEASIBLE because no single boat can carry enough qualified people
data;

set TASKS  := ta_1;
set PEOPLE := p_1 p_2;
set QUALIS := q_1 q_2;
set TOOLS  := to_1;
set PLACES := w_1 w_2;

param amountBoats    := 1;
param maxWorkingHours := 8;
param drivingSpeed   := 36;
param harbor         := 'w_1';

param duration := ta_1 3.0;

param taskPrio := ta_1 8;

param taskLocation := ta_1 w_2;

param distance : w_1 w_2 :=
                 w_1  0  36
                 w_2 36   0;

param hasQuali : q_1 q_2 :=
      p_1        1   0
      p_2        1   1;

# Needs 3x q_1 but only 2 people total exist -> impossible
param requiredQualis : q_1 q_2 :=
      ta_1        3   2;

param requiredTools : to_1 :=
      ta_1         1;

param stockTools := to_1 5;

end;
