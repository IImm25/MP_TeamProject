# TC-14: fixedToolAmount (already on the running boat) + new task's tool need EXCEEDS stockTools
# Boat 1 already has 2x to_1 fixed/committed (running task ta_1).
# New emergency task ta_2 needs 2x to_1, requires qualification q_2 (held only by p_2),
# and p_2 is already committed (fixedPerson) to boat 2. Total stockTools is only 3,
# boat 1 already holds 2 -> only 1 unit remains globally -> boat 2 cannot reach toolOnBoat>=2.
# KeepTools forces toolOnBoat[1,to_1] >= 2 (irrevocable).
# GlobalToolStock forces sum_b toolOnBoat[b,to_1] <= 3 -> toolOnBoat[2,to_1] <= 1.
# ta_2 needs requiredTools[ta_2,to_1]=2 -> ToolAvailable forces toolOnBoat[2,to_1] >= 2 IF ta_2 is
# placed on boat 2 -> contradiction -> ta_2 cannot be scheduled anywhere.
# Expect: OPTIMAL but ta_2 NOT scheduled (taskOnBoat[*,ta_2] = 0 everywhere).
# This directly tests UC-05 Alt Flow 7a ("insufficient resources on sea") combined with UC-02's
# hard stock invariant (q >= 0) interacting with a FIXED tool commitment.
data;

set TASKS  := ta_1 ta_2;
set PEOPLE := p_1 p_2;
set QUALIS := q_1 q_2;
set TOOLS  := to_1;
set PLACES := w_1 w_2 w_3;

param amountBoats    := 2;
param maxWorkingHours := 8;
param drivingSpeed   := 36;
param harbor         := 'w_1';

param duration :=
      ta_1 2.0
      ta_2 2.0;

param taskPrio :=
      ta_1 5
      ta_2 9;

param taskLocation :=
      ta_1 w_2
      ta_2 w_3;

param distance : w_1 w_2 w_3 :=
                 w_1  0  36  36
                 w_2 36   0  36
                 w_3 36  36   0;

# p_1 (already committed to boat 1 with ta_1) only holds q_1.
# p_2 only holds q_2. ta_2 requires q_2 -> ta_2 can ONLY go on a boat with p_2,
# and since p_1 is fixed to boat 1, p_2 (and therefore ta_2) must end up on boat 2.
param hasQuali : q_1 q_2 :=
      p_1        1   0
      p_2        0   1;

param requiredQualis : q_1 q_2 :=
      ta_1        1   0
      ta_2        0   1;

param requiredTools : to_1 :=
      ta_1         2
      ta_2         2;

param stockTools := to_1 3;

# ta_1 already running on boat 1, with its 2 tools physically already on board
param fixedBoat :=
      ta_1 1
      ta_2 0;

param fixedOrder :=
      ta_1 1
      ta_2 0;

# p_2 is already committed to boat 2 (e.g. crewed up for a different running task earlier,
# or simply assigned ahead of time) - this forces ta_2 onto boat 2, where stock is the issue.
param fixedPerson := p_1 1 p_2 2;

# the 2 tools already committed/loaded on boat 1 cannot be taken back
param fixedToolAmount : to_1 :=
      1            2
      2            0;

end;
