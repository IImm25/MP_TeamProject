# TC-25: Havarie scenario - fixed running task + new emergency task with tight time budget
# UC-05 Invariant: "Tasks with the status FIXED cannot be altered, moved, or removed by the system"
# UC-05 Alt Flow 7a: "the system detects that no active boat carries the required tools or 
#    qualified personnel on sea, or the working time limit would be completely exhausted"
#
# Setup: ta_1 is FIXED on boat 1 (already running, nearly at time limit).
#        A havarie task ta_2 arrives requiring the same boat.
#        Adding ta_2 would exceed maxWorkingHours.
#
# Expected (per UC-05): 
#   - ta_1 MUST remain scheduled (cannot be removed)
#   - ta_2 should be scheduled if possible, otherwise left unscheduled
#   - If ta_2 cannot fit: OPTIMAL with ta_1 scheduled, ta_2 NOT scheduled
#   - The system must NOT report INFEASIBLE just because ta_2 can't be added
#
# Actual (current model): 
#   - TimeLimit applies to ALL tasks on the boat
#   - If ta_1 + ta_2 exceeds limit: INFEASIBLE (violates UC-05 - ta_1 would be removed)
#   - If only ta_1 exceeds limit: INFEASIBLE (also violates UC-05)
#
# Test Result: CONFIRMS BUG - TimeLimit should not force INFEASIBLE when fixed tasks exist
# Expected: OPTIMAL, taskOnBoat[1,ta_1] = 1 (fixed task MUST be scheduled)
#           taskOnBoat[1,ta_2] = 0 (cannot fit) or 1 (if can fit)
# Actual: PROBLEM HAS NO INTEGER FEASIBLE SOLUTION
# Model output: "PROBLEM HAS NO INTEGER FEASIBLE SOLUTION"
# Fixed task ta_1 is REMOVED from solution, violating UC-05 invariant
#
data;

set TASKS  := ta_1 ta_2;
set PEOPLE := p_1;
set QUALIS := q_1;
set TOOLS  := to_1;
set PLACES := w_1 w_2 w_3;

param amountBoats    := 1;
param maxWorkingHours := 5;  # Tight 5 hour limit
param drivingSpeed   := 36;
param harbor         := 'w_1';

# ta_1 takes 4 hours, travel to w_2 is 1 hour each way = 6 hours total > 5 hour limit
# ta_2 takes 1 hour, travel to w_3 from w_2 is 1 hour = would add more
param duration := 
      ta_1 4.0
      ta_2 1.0;

param taskPrio := 
      ta_1 5
      ta_2 9;  # High priority havarie task

param taskLocation := 
      ta_1 w_2
      ta_2 w_3;

param distance : w_1 w_2 w_3 := 
                 w_1  0  36  72
                 w_2 36   0  36
                 w_3 72  36   0;

param hasQuali : q_1 := 
      p_1        1;

param requiredQualis : q_1 := 
      ta_1        1
      ta_2        1;

param requiredTools : to_1 := 
      ta_1         1
      ta_2         1;

param stockTools := to_1 5;

# ta_1 is FIXED on boat 1 - cannot be removed per UC-05
param fixedBoat := 
      ta_1 1
      ta_2 -1;  # ta_2 is new, not fixed

param fixedPerson := p_1 1;

param fixedToolAmount : to_1 := 
      1            1;

end;
