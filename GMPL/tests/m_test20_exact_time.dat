# Beschreibung: Genaues Zeitlimit
# Szenario:
# - A1 dauert 8.0 Stunden. maxWorkingHours ist 8.
# - Es muss exakt passen (<= Bedingung).
# Maximize WorkHours: 8.
data;
set TASKS := A1;
set QUALIS := Tech;
set PEOPLE := P1;
set TOOLS := W1;

param amountBoats := 1;
param maxWorkingHours := 8;

param duration := A1 8;

param hasQuali := P1 Tech 1;
param requiredQualis := A1 Tech 1;
param requiredTools := A1 W1 0;
param stockTools := W1 0;
end;
