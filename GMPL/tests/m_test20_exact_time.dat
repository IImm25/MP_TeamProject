# Description: Exact time limit.
# Scenario: A1 has a duration of 8.0 hours and maxWorkingHours is 8.
# Reasoning: The constraint is defined as a non-strict inequality (≤), so tasks that exactly match the limit are valid.
# Therefore A1 fully occupies one boat without violating the time constraint.
# Expected result: A1 is scheduled successfully (fits exactly within the limit).
# Maximize WorkHours: 8.
data;
set TASKS := A1;
set QUALIS := Tech;
set PEOPLE := P1;
set TOOLS := W1;

param amountBoats := 1;
param maxWorkingHours := 8;

param duration := A1 8;

param hasQuali := P1 Tech 1;
param requiredQualis := A1 Tech 1;
param requiredTools := A1 W1 0;
param stockTools := W1 0;
end;
