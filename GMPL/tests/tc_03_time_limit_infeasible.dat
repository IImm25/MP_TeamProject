# TC-03: Time limit too tight to complete any task including travel
# Travel w_1 -> w_2: 36km / 36kmh = 1h each way = 2h travel + 6h task = 8h total
# maxWorkingHours = 3 -> INFEASIBLE expected
# UC-04 Alt Flow 5a: system must detect impossible requirements
data;

set TASKS  := ta_1;
set PEOPLE := p_1;
set QUALIS := q_1;
set TOOLS  := to_1;
set PLACES := w_1 w_2;

param amountBoats    := 1;
param maxWorkingHours := 3;
param drivingSpeed   := 36;
param harbor         := 'w_1';

param duration := ta_1 6.0;

param taskPrio := ta_1 9;

param taskLocation := ta_1 w_2;

param distance : w_1 w_2 :=
                 w_1  0  36
                 w_2 36   0;

param hasQuali : q_1 :=
      p_1        1;

param requiredQualis : q_1 :=
      ta_1        1;

param requiredTools : to_1 :=
      ta_1         1;

param stockTools := to_1 5;

end;
