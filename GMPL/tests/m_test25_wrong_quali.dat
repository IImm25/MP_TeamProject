# Description: Qualification mismatch (wrong person).
# Scenario: A1 requires qualification Q1. P1 only has qualification Q2.
# Reasoning: Presence on the boat is not sufficient; the QualiCheck requires matching qualifications.
# Since no person satisfies Q1, A1 cannot be executed. Combined with AtLeastOneTaskGlobal (which
# forces at least one task), the problem has no valid solution.
# Expected result: INFEASIBLE – the solver finds no valid solution.
# Maximize WorkHours: INFEASIBLE.
data;
set TASKS := A1;
set QUALIS := Q1 Q2;
set PEOPLE := P1;
set TOOLS := W1;

param amountBoats := 1;
param maxWorkingHours := 10;

param duration := A1 5;

param hasQuali := P1 Q1 0 P1 Q2 1;
param requiredQualis := A1 Q1 1 A1 Q2 0;
param requiredTools := A1 W1 0;
param stockTools := W1 0;
end;
