# Beschreibung: Qualifikations-Mismatch (Falsche Person)
# Szenario:
# - Aufgabe A1 benötigt Qualifikation Q1.
# - P1 hat Qualifikation Q2.
# - P1 ist auf dem Boot.
# - Erwartung: A1 kann NICHT ausgeführt werden, obwohl jemand da ist, da die Quali nicht passt.
# Maximize WorkHours: 0.
data;
set TASKS := A1;
set QUALIS := Q1 Q2;
set PEOPLE := P1;
set TOOLS := W1;

param amountBoats := 1;
param maxWorkingHours := 10;

param duration := A1 5;

param hasQuali := P1 Q1 0 P1 Q2 1;
param requiredQualis := A1 Q1 1 A1 Q2 0;
param requiredTools := A1 W1 0;
param stockTools := W1 0;
end;
