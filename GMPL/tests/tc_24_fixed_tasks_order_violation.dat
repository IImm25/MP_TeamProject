# TC-24: Fixed tasks CAN be reordered without fixedStartTime parameter
# UC-05 Invariant: "Tasks with the status FIXED cannot be altered, moved, or removed by the system"
# 
# Setup: Two tasks ta_1 (low prio) and ta_2 (high prio) are FIXED on boat 1.
# fixedStartTime is NOT set, so model can optimize start times.
#
# Expected (per UC-05): Original sequence order should be preserved
#   - ta_1 should start first, ta_2 second
#   - after[1,ta_1,ta_2] = 1, isFirst[1,ta_1] = 1
#
# Actual (current model): Model reorders tasks based on priority optimization
#   - The model enforces fixedBoat (task stays on boat) but NOT sequence order
#   - Without fixedStartTime, KeepFixedStartTime constraint doesn't apply
#
# Test Result: CONFIRMS BEHAVIOR - fixedStartTime parameter needed to preserve order
# Expected: ta_1 starts first (startTime[1,ta_1] < startTime[1,ta_2])
# Actual: ta_2 starts before ta_1 due to higher priority
# Model output: INTEGER OPTIMAL SOLUTION FOUND
# Note: With fixedStartTime set, order WOULD be preserved
#
data;

set TASKS  := ta_1 ta_2;
set PEOPLE := p_1 p_2;
set QUALIS := q_1;
set TOOLS  := to_1;
set PLACES := w_1 w_2 w_3;

param amountBoats    := 1;
param maxWorkingHours := 10;
param drivingSpeed   := 36;
param harbor         := 'w_1';

param duration := 
      ta_1 2.0
      ta_2 2.0;

param taskPrio := 
      ta_1 1   # Lower priority - model might want to do this last
      ta_2 9;  # Higher priority - model might want to do this first

param taskLocation := 
      ta_1 w_2
      ta_2 w_3;

param distance : w_1 w_2 w_3 := 
                 w_1  0  36  72
                 w_2 36   0  36
                 w_3 72  36   0;

param hasQuali : q_1 := 
      p_1        1
      p_2        1;

param requiredQualis : q_1 := 
      ta_1        1
      ta_2        1;

param requiredTools : to_1 := 
      ta_1         1
      ta_2         1;

param stockTools := to_1 10;

# Both tasks are FIXED on boat 1 but WITHOUT fixedStartTime
# UC-05 requires that their sequence order is preserved
# However, without fixedStartTime, the model CAN reorder them based on priority
param fixedBoat := 
      ta_1 1
      ta_2 1;

# NOTE: fixedStartTime is NOT set - this allows the model to optimize start times
# If fixedStartTime were set, the order would be preserved

param fixedPerson := p_1 1 p_2 1;

param fixedToolAmount : to_1 := 
      1            2;

end;
